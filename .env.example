# iLink Web 端环境变量示例（复制为 .env 或在 IDE/系统中配置，勿提交真实密码）

# Spring 数据源（生产环境必填；dev 可在 application-dev.yml 中配置默认值）
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/ilink?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=

# Flyway Maven 插件（mvn flyway:migrate 时使用）
FLYWAY_USER=root
FLYWAY_PASSWORD=

# 可选
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8090
